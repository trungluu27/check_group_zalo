<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow unsigned executable memory (needed by Python / PyInstaller bootloader) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow JIT (some Qt / Python paths use it) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Disable library validation so bundled .dylib/.framework can load -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow DYLD environment variables (PyInstaller bootloader needs these) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Disable executable page protection (needed for some Python extensions) -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>

    <!-- Selenium automates Chrome via AppleEvents -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Network access (Selenium / HTTP) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
